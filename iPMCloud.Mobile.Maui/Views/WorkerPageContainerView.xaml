<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="iPMCloud.Mobile.Views.WorkerPageContainerView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vo="clr-namespace:iPMCloud.Mobile.vo">

    <Grid
        x:Name="WorkerPage_Container"
        Margin="0,0,0,14"
        Padding="0"
        HorizontalOptions="Fill"
        IsVisible="False"
        RowSpacing="0"
        VerticalOptions="Fill">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid
            Grid.Row="0"
            Margin="0"
            Padding="10,10,10,10"
            ColumnSpacing="0"
            HeightRequest="54"
            HorizontalOptions="Fill">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="btn_worker_back"
                Grid.Column="0"
                Margin="3,2,2,2"
                Padding="1"
                BackgroundColor="Transparent"
                HorizontalOptions="Start"
                Stroke="Transparent"
                VerticalOptions="Center">
                <Grid
                    Margin="0"
                    Padding="0"
                    ColumnSpacing="0"
                    HeightRequest="38"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image
                        x:Name="btn_worker_back_img"
                        Grid.Column="0"
                        Margin="0,0,0,0"
                        HeightRequest="30"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        WidthRequest="30" />
                    <Label
                        Grid.Column="1"
                        Margin="0"
                        FontSize="18"
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="Start"
                        LineBreakMode="TailTruncation"
                        Text="ZURÜCK"
                        TextColor="#2f84bd"
                        VerticalOptions="Center" />
                </Grid>
            </Border>


            <Border
                Grid.Column="1"
                Margin="3,2,2,2"
                Padding="1"
                BackgroundColor="#041d43"
                HorizontalOptions="End"
                VerticalOptions="Center">
                <VerticalStackLayout
                    x:Name="btn_workercategorysearch"
                    Margin="0"
                    Padding="0"
                    BackgroundColor="#042d53"
                    HeightRequest="38"
                    HorizontalOptions="End"
                    Spacing="0"
                    VerticalOptions="Center"
                    WidthRequest="38">
                    <Image
                        x:Name="btn_workercategorysearch_img"
                        Margin="0,4,0,0"
                        HeightRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="30" />
                </VerticalStackLayout>
            </Border>
            <Border
                Grid.Column="2"
                Margin="3,2,2,2"
                Padding="1"
                BackgroundColor="#041d43"
                HorizontalOptions="End"
                VerticalOptions="Center">
                <VerticalStackLayout
                    x:Name="btn_workernamesearch"
                    Margin="0"
                    Padding="0"
                    BackgroundColor="#042d53"
                    HeightRequest="38"
                    HorizontalOptions="End"
                    Spacing="0"
                    VerticalOptions="Center"
                    WidthRequest="38">
                    <Image
                        x:Name="btn_workernamesearch_img"
                        Margin="0,4,0,0"
                        HeightRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="30" />
                </VerticalStackLayout>
            </Border>
            <Border
                Grid.Column="3"
                Margin="3,2,2,2"
                Padding="1"
                BackgroundColor="#041d43"
                HorizontalOptions="End"
                VerticalOptions="Center">
                <VerticalStackLayout
                    x:Name="btn_workerbuildingsearch"
                    Margin="0"
                    Padding="0"
                    BackgroundColor="#042d53"
                    HeightRequest="38"
                    HorizontalOptions="End"
                    Spacing="0"
                    VerticalOptions="Center"
                    WidthRequest="38">
                    <Image
                        x:Name="btn_workerbuildingsearch_img"
                        Margin="0,4,0,0"
                        HeightRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="30" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            x:Name="entry_workersearch_container"
            Grid.Row="1"
            Margin="0"
            Padding="0"
            BackgroundColor="#245d83"
            ColumnSpacing="0"
            HorizontalOptions="Fill"
            IsVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <VerticalStackLayout
                Grid.Column="0"
                Margin="10,0,10,0"
                Padding="0"
                BackgroundColor="#245d83"
                HorizontalOptions="Fill"
                Spacing="0">
                <Label
                    x:Name="lb_workerbuildingsearche"
                    Margin="0"
                    Padding="0"
                    FontSize="12"
                    HorizontalOptions="Fill"
                    HorizontalTextAlignment="Start"
                    Text="Objekt suchen:"
                    TextColor="#aaaaaa"
                    VerticalOptions="Start" />
                <vo:CustomEntry
                    x:Name="entry_workersearch"
                    Margin="0,-10,0,0"
                    BackgroundColor="Transparent"
                    CornerRadius="0"
                    FontSize="16"
                    HorizontalOptions="Fill"
                    HorizontalTextAlignment="Start"
                    Text=""
                    TextChanged="Entry_workersearch_TextChanged"
                    TextColor="#ffffff"
                    VerticalOptions="Start" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView
            x:Name="list_worker_scroll"
            Grid.Row="2"
            Margin="0,0,0,0"
            Padding="0"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
            <StackLayout
                x:Name="list_worker"
                Margin="0"
                Padding="0"
                HorizontalOptions="Fill"
                IsVisible="False"
                Orientation="Vertical"
                Spacing="0"
                VerticalOptions="Fill" />
        </ScrollView>
        <BoxView
            Grid.Row="3"
            Margin="0,0,0,0"
            BackgroundColor="Black"
            HeightRequest="1"
            HorizontalOptions="Fill"
            VerticalOptions="Start" />

    </Grid>

</ContentView>
