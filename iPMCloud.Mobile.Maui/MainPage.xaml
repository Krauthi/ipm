<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="iPMCloud.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:views="clr-namespace:iPMCloud.Mobile.Views"
    xmlns:vo="clr-namespace:iPMCloud.Mobile.vo"
    BackgroundColor="Black"
    ClassId="MainPage">

    <AbsoluteLayout
        Margin="0,0,0,0"
        Padding="0,0,0,0"
        AbsoluteLayout.LayoutBounds="0,0,1,1"
        AbsoluteLayout.LayoutFlags="All"
        BackgroundColor="Transparent">

        <!--<AbsoluteLayout
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            BackgroundColor="Transparent">
            <Image
                x:Name="backgroundIMG"
                Margin="0,0,0,0"
                AbsoluteLayout.LayoutBounds="0,0,1,1"
                AbsoluteLayout.LayoutFlags="All"
                Aspect="Fill"
                HorizontalOptions="Center"
                Opacity="1"
                Source="backgroundgray1c.jpg"
                VerticalOptions="End" />
        </AbsoluteLayout>-->

        <AbsoluteLayout
            AbsoluteLayout.LayoutBounds="1,1,1,1"
            AbsoluteLayout.LayoutFlags="All"
            BackgroundColor="Transparent">
            <Grid
                x:Name="lbAppInfo"
                Margin="0"
                Padding="0"
                AbsoluteLayout.LayoutBounds="1,1,1,1"
                AbsoluteLayout.LayoutFlags="All"
                BackgroundColor="Black"
                HorizontalOptions="Fill"
                VerticalOptions="End">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label
                    x:Name="lb_version"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    FontSize="10"
                    HorizontalOptions="End"
                    Text=""
                    TextColor="#0078d7"
                    VerticalOptions="Center"
                    VerticalTextAlignment="Center" />
                <Image
                    x:Name="img_onlinestate"
                    Grid.Column="1"
                    Margin="0,0,0,0"
                    HeightRequest="12"
                    HorizontalOptions="End"
                    Source="isonline.png"
                    WidthRequest="12" />
                <Image
                    x:Name="img_gpsstate"
                    Grid.Column="2"
                    Margin="0,0,0,1"
                    HeightRequest="12"
                    HorizontalOptions="End"
                    Source="gpsoff2.png"
                    WidthRequest="12" />
                <Label
                    x:Name="lb_onlinestate"
                    Grid.Column="3"
                    Margin="0,0,30,0"
                    FontSize="10"
                    HorizontalOptions="End"
                    Text=""
                    TextColor="#0078d7"
                    VerticalOptions="Center"
                    VerticalTextAlignment="Center" />
            </Grid>
        </AbsoluteLayout>


        <Grid
            x:Name="StartPage_Container"
            Margin="0,0,0,12"
            Padding="0"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            HorizontalOptions="Fill"
            IsVisible="False"
            RowSpacing="0"
            VerticalOptions="Fill">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="0"
                Padding="10"
                ColumnSpacing="0"
                HeightRequest="48"
                HorizontalOptions="Fill"
                RowSpacing="0">

                <Grid.ColumnDefinitions>
                    <!--  links: Menübutton + Badge  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  mitte: Titel  -->
                    <ColumnDefinition Width="*" />
                    <!--  rechts: Userbild  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  rechts: Usertexte  -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Menübutton  -->
                <Border
                    Grid.Column="0"
                    Margin="3,2,2,2"
                    Padding="1"
                    BackgroundColor="Transparent"
                    HorizontalOptions="Start"
                    Stroke="Transparent"
                    VerticalOptions="Center">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.3"
                            Radius="5"
                            Offset="2,2" />
                    </Border.Shadow>

                    <!--  klickbare Fläche  -->
                    <Grid
                        x:Name="btn_mainmenu"
                        Margin="0"
                        Padding="0"
                        BackgroundColor="Transparent"
                        HeightRequest="38"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        WidthRequest="38">

                        <Image
                            x:Name="btn_mainsettings_img"
                            Margin="0"
                            HeightRequest="30"
                            HorizontalOptions="Start"
                            VerticalOptions="Center"
                            WidthRequest="30" />
                    </Grid>
                </Border>

                <!--  Badge/Counter über dem Menübutton (Overlay)  -->
                <Grid
                    x:Name="btn_StartPage_frame_count"
                    Grid.Column="0"
                    Margin="-20,3,5,0"
                    HeightRequest="21"
                    HorizontalOptions="Start"
                    IsVisible="False"
                    VerticalOptions="Start"
                    WidthRequest="21">

                    <Image
                        HorizontalOptions="Fill"
                        Source="dot2.png"
                        VerticalOptions="Fill" />

                    <Label
                        x:Name="btn_StartPage_count"
                        Margin="0,0,0,0"
                        FontSize="Default"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Text=""
                        TextColor="#ffffff"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                </Grid>

                <!--  Titel  -->
                <Label
                    Grid.Column="1"
                    Margin="0"
                    FontSize="18"
                    HorizontalOptions="Fill"
                    HorizontalTextAlignment="Start"
                    LineBreakMode="TailTruncation"
                    Text="START"
                    TextColor="#ffffff"
                    VerticalOptions="Center" />

                <!--  Userbild rechts  -->
                <Border
                    x:Name="frm_img_LoginUser"
                    Grid.Column="2"
                    Margin="0,0,5,0"
                    Padding="0"
                    HeightRequest="40"
                    HorizontalOptions="End"
                    StrokeShape="RoundRectangle 20"
                    VerticalOptions="Center"
                    WidthRequest="40">
                    <Image
                        x:Name="img_LoginUser"
                        Margin="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>

                <!--  Usertexte rechts  -->
                <VerticalStackLayout
                    Grid.Column="3"
                    Margin="0"
                    HorizontalOptions="End"
                    Spacing="0"
                    VerticalOptions="Center">

                    <Label
                        x:Name="lb_LoginUser"
                        Margin="0"
                        FontSize="14"
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="End"
                        LineBreakMode="TailTruncation"
                        Text=""
                        TextColor="#ffffff"
                        VerticalOptions="Center" />

                    <Label
                        x:Name="lb_LoginCustomer"
                        Margin="0"
                        FontSize="10"
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="End"
                        LineBreakMode="TailTruncation"
                        Text=""
                        TextColor="#ffffff"
                        VerticalOptions="Center" />
                </VerticalStackLayout>

            </Grid>


            <BoxView
                Grid.Row="1"
                Margin="0,0,0,0"
                BackgroundColor="Gray"
                HeightRequest="1"
                HorizontalOptions="Fill"
                VerticalOptions="Start" />


            <VerticalStackLayout
                Grid.Row="2"
                Margin="0"
                Padding="0"
                BackgroundColor="#34000000"
                HorizontalOptions="Fill"
                Spacing="0"
                VerticalOptions="Start">

                <Grid
                    x:Name="lastBuilding_Container"
                    Margin="0"
                    Padding="10,0,10,0"
                    ColumnSpacing="0"
                    HorizontalOptions="Fill"
                    IsVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout
                        Grid.Column="0"
                        Margin="0"
                        Padding="0,0,10,0"
                        HorizontalOptions="Fill"
                        Spacing="0">

                        <Grid
                            Margin="0"
                            Padding="0"
                            ColumnSpacing="0"
                            HorizontalOptions="Fill">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <VerticalStackLayout
                                Grid.Column="0"
                                Margin="0"
                                Padding="0"
                                HorizontalOptions="Fill"
                                Spacing="0">
                                <Label
                                    Margin="0"
                                    FontSize="11"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Letztes Objekt:"
                                    TextColor="#aaaaaa"
                                    VerticalOptions="Center" />
                                <Label
                                    x:Name="last_building_name"
                                    Margin="0,-2,0,0"
                                    Padding="0"
                                    FontSize="13"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text=""
                                    TextColor="#ffffff"
                                    VerticalOptions="Center" />
                            </VerticalStackLayout>

                            <Border
                                x:Name="btn_objektinfo_container"
                                Grid.Column="1"
                                Margin="2,0,0,0"
                                Padding="1"
                                BackgroundColor="Transparent"
                                HorizontalOptions="End"
                                IsVisible="True"
                                VerticalOptions="Start">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.3"
                                        Radius="5"
                                        Offset="2,2" />
                                </Border.Shadow>
                                <StackLayout
                                    x:Name="btn_objektinfo"
                                    Margin="0"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    HeightRequest="26"
                                    HorizontalOptions="End"
                                    Spacing="0"
                                    VerticalOptions="Center"
                                    WidthRequest="26">
                                    <Image
                                        x:Name="btn_objektinfo_img"
                                        Margin="0,0,0,0"
                                        HeightRequest="26"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="26" />
                                </StackLayout>
                            </Border>
                        </Grid>
                        <VerticalStackLayout
                            Margin="0"
                            Padding="0"
                            HorizontalOptions="Fill"
                            Spacing="0">
                            <Label
                                x:Name="last_building_address"
                                Margin="0,-2,0,0"
                                Padding="0"
                                FontSize="13"
                                HorizontalOptions="Fill"
                                HorizontalTextAlignment="Start"
                                Text=""
                                TextColor="#ffffff"
                                VerticalOptions="Center" />
                            <Label
                                x:Name="last_building_zip_city"
                                Margin="0,-2,0,0"
                                Padding="0"
                                FontSize="13"
                                HorizontalOptions="Fill"
                                HorizontalTextAlignment="Start"
                                Text=""
                                TextColor="#ffffff"
                                VerticalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                    <Border
                        Grid.Column="1"
                        Margin="2,0,3,0"
                        Padding="1"
                        BackgroundColor="#041d43"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.3"
                                Radius="5"
                                Offset="2,2" />
                        </Border.Shadow>
                        <StackLayout
                            x:Name="btn_alertmessage_container"
                            Margin="0"
                            Padding="0"
                            BackgroundColor="#042d53"
                            HeightRequest="40"
                            HorizontalOptions="End"
                            Spacing="0"
                            VerticalOptions="Center"
                            WidthRequest="40">
                            <Image
                                x:Name="btn_alertmessage_img"
                                Margin="0,0,0,0"
                                HeightRequest="30"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </StackLayout>
                    </Border>
                    <Border
                        Grid.Column="2"
                        Margin="3,0,3,0"
                        Padding="1"
                        BackgroundColor="#041d43"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.3"
                                Radius="5"
                                Offset="2,2" />
                        </Border.Shadow>
                        <StackLayout
                            x:Name="btn_message_container"
                            Margin="0"
                            Padding="0"
                            BackgroundColor="#042d53"
                            HeightRequest="40"
                            HorizontalOptions="End"
                            Spacing="0"
                            VerticalOptions="Center"
                            WidthRequest="40">
                            <Image
                                x:Name="btn_message_img"
                                Margin="0,0,0,0"
                                HeightRequest="30"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </StackLayout>
                    </Border>
                    <Border
                        Grid.Column="3"
                        Margin="3,0,3,0"
                        Padding="1"
                        BackgroundColor="#041d43"
                        HorizontalOptions="End"
                        IsVisible="True"
                        VerticalOptions="Start">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.3"
                                Radius="5"
                                Offset="2,2" />
                        </Border.Shadow>
                        <StackLayout
                            x:Name="btn_objvalues_container"
                            Margin="0"
                            Padding="0"
                            BackgroundColor="#042d53"
                            HeightRequest="40"
                            HorizontalOptions="End"
                            Spacing="0"
                            VerticalOptions="Center"
                            WidthRequest="40">
                            <Image
                                x:Name="btn_objvalues_img"
                                Margin="0,0,0,0"
                                HeightRequest="30"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </StackLayout>
                    </Border>

                    <Border
                        Grid.Column="4"
                        Margin="3,0,0,0"
                        Padding="1"
                        BackgroundColor="#041d43"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Border.Shadow>
                            <Shadow
                                Brush="Black"
                                Opacity="0.3"
                                Radius="5"
                                Offset="2,2" />
                        </Border.Shadow>
                        <StackLayout
                            x:Name="btn_buildingout_container"
                            Margin="0"
                            Padding="0"
                            BackgroundColor="#042d53"
                            HeightRequest="40"
                            HorizontalOptions="End"
                            Spacing="0"
                            VerticalOptions="Center"
                            WidthRequest="40">
                            <Image
                                x:Name="btn_buildingout_img2"
                                Margin="0,0,0,0"
                                HeightRequest="30"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </StackLayout>
                    </Border>
                </Grid>


                <Border
                    x:Name="btn_buildingorder_container"
                    Margin="10,1,10,2"
                    Padding="1"
                    BackgroundColor="#041d43"
                    HorizontalOptions="Fill"
                    IsVisible="False">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.3"
                            Radius="5"
                            Offset="2,2" />
                    </Border.Shadow>
                    <StackLayout
                        x:Name="btn_buildingorder"
                        Margin="0"
                        Padding="5"
                        BackgroundColor="#042d53"
                        HeightRequest="40"
                        HorizontalOptions="Fill">
                        <Grid
                            Margin="10,0,0,0"
                            Padding="0"
                            ColumnSpacing="0"
                            HeightRequest="30"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image
                                x:Name="btn_buildingorder_limg"
                                Grid.Column="0"
                                Margin="0,0,15,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                            <VerticalStackLayout
                                Grid.Column="1"
                                Margin="0,-4,0,0"
                                Padding="0"
                                HorizontalOptions="Fill"
                                Spacing="0"
                                VerticalOptions="Center">
                                <Label
                                    Margin="0"
                                    Padding="0"
                                    FontSize="18"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Arbeiten auswählen"
                                    TextColor="#ffffff" />
                                <Label
                                    Margin="0,-3,0,0"
                                    Padding="0"
                                    FontSize="12"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="zum ausgewählten Objekt"
                                    TextColor="#aaaaaa" />
                            </VerticalStackLayout>
                            <Border
                                x:Name="btn_buildingorderToTime_count"
                                Grid.Column="2"
                                Margin="0"
                                Padding="5"
                                BackgroundColor="#ff0000"
                                HorizontalOptions="End"
                                IsVisible="False"
                                StrokeShape="RoundRectangle 5">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.3"
                                        Radius="5"
                                        Offset="2,2" />
                                </Border.Shadow>
                                <Label
                                    x:Name="btn_buildingorderToTime_counttext"
                                    Margin="0"
                                    Padding="0"
                                    FontSize="16"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"
                                    Text="13"
                                    TextColor="#ffffff"
                                    VerticalOptions="Center" />
                            </Border>
                            <Image
                                x:Name="btn_buildingorder_rimg"
                                Grid.Column="3"
                                Margin="10,0,0,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </Grid>
                    </StackLayout>
                </Border>

                <Border
                    x:Name="btn_inwork_container"
                    Margin="10,10,10,15"
                    Padding="1"
                    BackgroundColor="#04431d"
                    HorizontalOptions="Fill"
                    IsVisible="False">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.3"
                            Radius="5"
                            Offset="2,2" />
                    </Border.Shadow>
                    <StackLayout
                        x:Name="btn_inwork"
                        Margin="0"
                        Padding="5"
                        BackgroundColor="#04532d"
                        HeightRequest="40"
                        HorizontalOptions="Fill">
                        <Grid
                            Margin="10,0,0,0"
                            Padding="0"
                            ColumnSpacing="0"
                            HeightRequest="30"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image
                                x:Name="btn_inwork_limg"
                                Grid.Column="0"
                                Margin="0,0,15,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                            <VerticalStackLayout
                                Grid.Column="1"
                                Margin="0,-4,0,0"
                                Padding="0"
                                HorizontalOptions="Start"
                                Spacing="0"
                                VerticalOptions="Center">
                                <Label
                                    Margin="0"
                                    Padding="0"
                                    FontSize="18"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Aktuelle Arbeiten"
                                    TextColor="#ffffff" />
                                <Label
                                    Margin="0,-3,0,0"
                                    Padding="0"
                                    FontSize="12"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Hier sind Sie gerade dabei"
                                    TextColor="#aaaaaa" />
                            </VerticalStackLayout>
                            <Border
                                Grid.Column="2"
                                Margin="0"
                                Padding="5"
                                BackgroundColor="#009900"
                                HorizontalOptions="End"
                                StrokeShape="RoundRectangle 5">
                                <Border.Shadow>
                                    <Shadow
                                        Brush="Black"
                                        Opacity="0.3"
                                        Radius="5"
                                        Offset="2,2" />
                                </Border.Shadow>
                                <Label
                                    x:Name="inwork_start_count_text"
                                    Margin="0"
                                    Padding="0"
                                    FontSize="16"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"
                                    Text="1"
                                    TextColor="#ffffff"
                                    VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout
                                Grid.Column="3"
                                Margin="0,-4,0,0"
                                Padding="0"
                                HorizontalOptions="End"
                                Spacing="0"
                                VerticalOptions="Center">
                                <Label
                                    Margin="0,0,0,0"
                                    Padding="0"
                                    FontSize="12"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Seit"
                                    TextColor="#aaaaaa" />
                                <Label
                                    x:Name="inwork_starttime_text"
                                    Margin="0,-3,0,0"
                                    Padding="0"
                                    FontSize="20"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="End"
                                    Text="00:00"
                                    TextColor="#ffcc00" />
                            </VerticalStackLayout>
                        </Grid>
                    </StackLayout>
                </Border>


                <Image
                    x:Name="btn_nachbuchen_img"
                    Margin="5,-19,0,-60"
                    BindingContext="{x:Reference btn_nachbuchen_container}"
                    HeightRequest="70"
                    HorizontalOptions="Start"
                    IsVisible="{Binding Path=IsVisible}"
                    VerticalOptions="Start"
                    WidthRequest="90" />

                <Border
                    x:Name="btn_nachbuchen_container"
                    Margin="70,10,10,8"
                    Padding="1"
                    BackgroundColor="#041d43"
                    HorizontalOptions="Fill"
                    IsVisible="False">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.3"
                            Radius="5"
                            Offset="2,2" />
                    </Border.Shadow>
                    <StackLayout
                        x:Name="btn_nachbuchen"
                        Margin="0"
                        Padding="5"
                        BackgroundColor="#042d53"
                        HeightRequest="40"
                        HorizontalOptions="Fill">
                        <Grid
                            Margin="10,0,0,0"
                            Padding="0"
                            ColumnSpacing="0"
                            HeightRequest="30"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image
                                x:Name="btn_posnachbuchen_limg"
                                Grid.Column="0"
                                Margin="0,-3,0,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                            <Image
                                x:Name="btn_produktenachbuchen_limg"
                                Grid.Column="1"
                                Margin="-10,3,10,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                            <VerticalStackLayout
                                Grid.Column="2"
                                Margin="0,-4,0,0"
                                Padding="0"
                                HorizontalOptions="Fill"
                                Spacing="0"
                                VerticalOptions="Center">
                                <Label
                                    Margin="0"
                                    Padding="0"
                                    FontSize="18"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="Nachbuchen"
                                    TextColor="#ffffff" />
                                <Label
                                    Margin="0,-3,0,0"
                                    Padding="0"
                                    FontSize="12"
                                    HorizontalOptions="Fill"
                                    HorizontalTextAlignment="Start"
                                    Text="zu aktuellen Ausführungen"
                                    TextColor="#aaaaaa" />
                            </VerticalStackLayout>
                            <Image
                                x:Name="btn_nachbuchen_rimg"
                                Grid.Column="3"
                                Margin="10,0,0,0"
                                HeightRequest="30"
                                VerticalOptions="Center"
                                WidthRequest="30" />
                        </Grid>
                    </StackLayout>
                </Border>

            </VerticalStackLayout>


            <BoxView
                x:Name="lastBuilding_ContainerBottom"
                Grid.Row="3"
                Margin="0,0,0,10"
                BackgroundColor="Gray"
                HeightRequest="1"
                HorizontalOptions="Fill"
                VerticalOptions="Start" />


            <!--<ScrollView VerticalOptions="Fill" HorizontalOptions="Fill" Padding="0" Margin="0">-->

            <Grid
                Grid.Row="4"
                Margin="0"
                Padding="0"
                HorizontalOptions="Fill"
                RowSpacing="0"
                VerticalOptions="Fill">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid
                    Grid.Row="0"
                    Margin="10,5,10,10"
                    Padding="0"
                    BackgroundColor="Transparent"
                    ColumnSpacing="0"
                    HorizontalOptions="Fill"
                    VerticalOptions="Start">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

